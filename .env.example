# PagerDuty
PAGERDUTY_API_KEY=your-pagerduty-api-token-here

# GitHub Copilot (for AI-generated insights — run `copilot auth login` or set GITHUB_TOKEN)
GITHUB_TOKEN=your-github-token-here

# Optional overrides
PAGERDUTY_BASE_URL=https://api.pagerduty.com
COPILOT_MODEL=claude-sonnet-4-6
REPORT_TIMEZONE=UTC

# SMTP email delivery (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
REPORT_FROM_ADDRESS=
REPORT_TO_ADDRESSES=
